<Window x:Class="KitcoWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Kitco Widget"
        Width="805" Height="705"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        Background="#1e1e1e">

    <Border BorderBrush="#444" BorderThickness="1">
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Tabs + content -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <DockPanel Grid.Row="0"
                       Background="#2b2b2b"
                       MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Kitco Widget"
                           Foreground="White"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="13"/>
                <Button Content="✕"
                        Width="32"
                        Background="#2b2b2b"
                        Foreground="White"
                        BorderBrush="{x:Null}"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"/>
            </DockPanel>

            <!-- Tabs -->
            <TabControl Grid.Row="1"
                        Background="#1e1e1e"
                        BorderBrush="#444"
                        Foreground="White"
                        x:Name="Tabs">

                <!-- GOLD TAB -->
                <TabItem Header="Gold">
                    <wv2:WebView2 x:Name="GoldBrowser"/>
                </TabItem>

                <!-- SILVER TAB -->
                <TabItem Header="Silver">
                    <wv2:WebView2 x:Name="SilverBrowser"/>
                </TabItem>

            </TabControl>

        </Grid>
    </Border>
</Window>